### 1. Login as Employer (Get Token)
POST http://localhost:5000/api/auth/login
Content-Type: application/json

{
    "email": "employer@example.com",
    "password": "password123"
}

### 2. Login as Admin (Get Token)
POST http://localhost:5000/api/auth/login
Content-Type: application/json

{
    "email": "admin@internlink.com",
    "password": "password123"
}

### 3. Add Opportunity 1 - Software Developer Intern (Use token from step 1)
POST http://localhost:5000/api/opportunities
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
    "title": "Software Developer Intern",
    "company_name": "Safaricom",
    "type": "Internship",
    "location": "Nairobi",
    "duration": "6 months",
    "stipend": "KES 25,000/month",
    "deadline": "2026-09-30T00:00:00",
    "description": "Join our engineering team to build cutting-edge mobile and web applications.",
    "requirements": "3rd or 4th year Computer Science student",
    "required_skills": ["React", "Python", "Java", "SQL"]
}

### 4. Add Opportunity 2 - Finance Attachment
POST http://localhost:5000/api/opportunities
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
    "title": "Finance Attachment",
    "company_name": "KCB Bank",
    "type": "Attachment",
    "location": "Nairobi",
    "duration": "3 months",
    "stipend": "KES 15,000/month",
    "deadline": "2026-09-15T00:00:00",
    "description": "Gain hands-on experience in banking operations and financial analysis.",
    "requirements": "2nd or 3rd year Finance/Accounting student",
    "required_skills": ["Excel", "Financial Analysis", "Accounting"]
}

